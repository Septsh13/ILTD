{
  "name": "gsn-api",
  "version": "1.0.0",
  "description": "GSN Global Success Network API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node start.js",
    "build": "cd \"DP world\" && npm run build",
