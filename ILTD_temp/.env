# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clearpath_db
DB_USER=postgres
DB_PASSWORD=123456

# JWT
JWT_SECRET=clearpath_jwt_secret_2026_super_secure_key
JWT_EXPIRES_IN=8h

# AES-256 Encryption (must be exactly 32 characters)
ENCRYPTION_KEY=ClearPathKey12345678901234567890

# Server
PORT=3001
